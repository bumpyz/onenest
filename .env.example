# Copy this to .env.local and fill in real values. .env.local is gitignored.
# The EXPO_PUBLIC_ prefix is required so Expo injects these into the client bundle.
# Supabase's anon key is safe to expose; RLS policies in supabase/migrations/0002_rls.sql
# protect the data.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth client IDs (one per platform — Google requires this).
# Get these from https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Microsoft (Azure) Application (client) ID for external Outlook Calendar pairing.
# Register at portal.azure.com → Microsoft Entra ID → App registrations as a Single-page
# Application (SPA) with redirect URI http://localhost:8081/oauth/microsoft.
# Add Microsoft Graph delegated permissions: Calendars.Read, offline_access, User.Read.
# No client secret needed (PKCE).
EXPO_PUBLIC_MICROSOFT_CLIENT_ID=

# Google Places API key — powers the location autocomplete in events + Settings.
# In Google Cloud Console: APIs & Services → Library → enable "Places API (New)"
# (NOT the legacy "Places API"). Then Credentials → Create API key, and restrict it:
#   Application restrictions → HTTP referrers → http://localhost:8081/* (+ prod domain)
#   API restrictions → Restrict key → "Places API (New)" only
# An unrestricted key is a billing-risk-shaped liability if it ever leaks.
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# OAuth client_id for the Calendar refresh proxy — distinct from the OAuth client
# Supabase Auth uses for user sign-in. Create a new "Web application" client at
# https://console.cloud.google.com/apis/credentials with redirect URI
# http://localhost:8081/oauth/google. The matching client_secret is stored in Supabase
# Vault as google_calendar_client_secret (the edge function reads it server-side).
EXPO_PUBLIC_GOOGLE_CALENDAR_CLIENT_ID=
